# Server port (default is 3000)
PORT=3000

# Admin Password (needed to access the dashboard /admin.html and registrations APIs)
ADMIN_PASSWORD=GLAAdmin2026

# Public URL of the server (needed for Google Sheet audio links when running locally)
# e.g., your Serveo tunnel URL: https://c2bd5b0431cf27e2-117-199-105-83.serveousercontent.com
PUBLIC_URL=https://c2bd5b0431cf27e2-117-199-105-83.serveousercontent.com

# Google Sheet Web App endpoint URL
# Set this up by clicking Extensions -> Apps Script inside your Google Sheet
GOOGLE_SHEET_WEBAPP_URL=https://script.google.com/macros/s/XXXXXXXXXXXXXXXXXXXX/exec

# Cloudinary Storage Configuration API Keys (Only for public cloud deployment)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
